{
  "productName": "Probe",
  "identifier": "com.probe.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../frontend"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../frontend"
    }
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1280,
        "height": 800,
        "titleBarStyle": "Overlay"
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/icon.png"
    ],
    "externalBin": [
      "probe-engine"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCNjFCQzYwM0NDRjg2NzAKUldSd2hzODhZTHhoYTVWb2dWQitiUUlqaG1pYzMxbVdsUU9BeG5RMU9JZ21seG5Ya09DOWw0c28K",
      "endpoints": [
        "https://github.com/ChickmagnetL/Probe/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
