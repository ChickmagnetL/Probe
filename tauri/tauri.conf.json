{
  "productName": "Probe",
  "version": "0.0.3",
  "identifier": "com.probe.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../frontend"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../frontend"
    }
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1280,
        "height": 800,
        "titleBarStyle": "Overlay"
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/icon.png"
    ],
    "externalBin": [
      "probe-engine"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": null
    }
  }
}
